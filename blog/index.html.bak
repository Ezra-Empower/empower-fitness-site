        <a href="/blog/sciatica-physical-therapy-boca-raton" class="read-more">Read More →</a>
      </div>
    </div>

    <div class="blog-card" data-category="injury">
      <div class="blog-card-img"><img src="https://images.unsplash.com/photo-1755682212897-65024adec786?w=400&h=220&fit=crop&auto=format&q=80" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" onerror="this.style.display='none'" /></div>
